# Marque la racine de configuration Lombok pour ce module.
config.stopBubbling = true

# Ajoute @lombok.Generated sur tout le code généré par Lombok (getters, setters,
# equals/hashCode, builders, constructeurs @NonNull...). JaCoCo ignore le code
# annoté @Generated : on ne mesure ainsi que le code métier réellement écrit,
# pas le boilerplate généré (même principe que l'exclusion du package DTO).
lombok.addLombokGeneratedAnnotation = true
